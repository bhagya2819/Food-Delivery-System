{
  "id": "food-delivery",
  "realm": "food-delivery",
  "enabled": true,
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "roles": {
    "realm": [
      { "name": "CUSTOMER" },
      { "name": "RESTAURANT_OWNER" },
      { "name": "DELIVERY_PARTNER" },
      { "name": "ADMIN" }
    ]
  },
  "clients": [
    {
      "clientId": "food-delivery-web",
      "name": "Food Delivery Web App",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:5174/*", "http://localhost:5173/*", "http://localhost:3000/*"],
      "webOrigins": ["http://localhost:5174", "http://localhost:5173", "http://localhost:3000"],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false
    },
    {
      "clientId": "food-delivery-gateway",
      "name": "API Gateway",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    }
  ]
}
